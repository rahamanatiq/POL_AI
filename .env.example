# Django Core Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration (if switching from SQLite to PostgreSQL)
# DB_NAME=pol_tracking_db
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# ==========================================
# Lilian AI - External LLM Configuration
# ==========================================
# Currently, Lilian AI uses local rule-based NLP (no LLM required).
# However, if you upgrade to an external LLM, you can store those API keys here:

# OPENAI_API_KEY=sk-your-openai-api-key
# CLAUDE_API_KEY=your-anthropic-api-key
# LLM_MODEL_NAME=gpt-4o
